{
  "name": "@redpandamc/tree-sitter-sql-extended",
  "version": "0.3.11",
  "description": "Tree-sitter SQL grammar with dialect extensions (Databricks, Spark, PostgreSQL, MySQL)",
  "main": "bindings/node",
  "types": "bindings/node",
  "scripts": {
    "install": "node scripts/generate.js && node-gyp-build",
    "generate": "node scripts/generate.js",
    "generate:databricks": "node scripts/generate.js databricks",
    "generate:spark": "node scripts/generate.js spark",
    "generate:postgres": "node scripts/generate.js postgres",
    "generate:mysql": "node scripts/generate.js mysql",
    "generate:snowflake": "node scripts/generate.js snowflake",
    "test:corpus:snowflake": "cd snowflake && npx --yes --package=tree-sitter-cli@v0.26.3 -- tree-sitter test",
    "generate:bigquery": "node scripts/generate.js bigquery",
    "test:corpus:bigquery": "cd bigquery && npx --yes --package=tree-sitter-cli@v0.26.3 -- tree-sitter test",
    "generate:mariadb": "node scripts/generate.js mariadb",
    "test:corpus:mariadb": "cd mariadb && npx --yes --package=tree-sitter-cli@v0.26.3 -- tree-sitter test",
    "generate:sqlite": "node scripts/generate.js sqlite",
    "test:corpus:sqlite": "cd sqlite && npx --yes --package=tree-sitter-cli@v0.26.3 -- tree-sitter test",
    "generate:hive": "node scripts/generate.js hive",
    "test:corpus:hive": "cd hive && npx --yes --package=tree-sitter-cli@v0.26.3 -- tree-sitter test",
    "generate:oracle": "node scripts/generate.js oracle",
    "test:corpus:oracle": "cd oracle && npx --yes --package=tree-sitter-cli@v0.26.3 -- tree-sitter test",
    "generate:db2": "node scripts/generate.js db2",
    "test:corpus:db2": "cd db2 && npx --yes --package=tree-sitter-cli@v0.26.3 -- tree-sitter test",
    "generate:tsql": "node scripts/generate.js tsql",
    "test:corpus:tsql": "cd tsql && npx --yes --package=tree-sitter-cli@v0.26.3 -- tree-sitter test",
    "generate:duckdb": "node scripts/generate.js duckdb",
    "test:corpus:duckdb": "cd duckdb && npx --yes --package=tree-sitter-cli@v0.26.3 -- tree-sitter test",
    "generate:trino": "node scripts/generate.js trino",
    "test:corpus:trino": "cd trino && npx --yes --package=tree-sitter-cli@v0.26.3 -- tree-sitter test",
    "generate:athena": "node scripts/generate.js athena",
    "test:corpus:athena": "cd athena && npx --yes --package=tree-sitter-cli@v0.26.3 -- tree-sitter test",
    "generate:all": "npm run generate && npm run generate:spark && npm run generate:postgres && npm run generate:mysql && npm run generate:databricks && npm run generate:snowflake && npm run generate:bigquery && npm run generate:mariadb && npm run generate:sqlite && npm run generate:hive && npm run generate:oracle && npm run generate:db2 && npm run generate:tsql && npm run generate:duckdb && npm run generate:trino && npm run generate:athena",
    "generate:force": "npx --yes --package=tree-sitter-cli@v0.26.3 -- tree-sitter generate",
    "build": "npm run generate && node-gyp-build",
    "test:corpus": "npx --yes --package=tree-sitter-cli@v0.26.3 -- tree-sitter test",
    "test:corpus:databricks": "cd databricks && npx --yes --package=tree-sitter-cli@v0.26.3 -- tree-sitter test",
    "test:corpus:spark": "cd spark && npx --yes --package=tree-sitter-cli@v0.26.3 -- tree-sitter test",
    "test:corpus:postgres": "cd postgres && npx --yes --package=tree-sitter-cli@v0.26.3 -- tree-sitter test",
    "test:corpus:mysql": "cd mysql && npx --yes --package=tree-sitter-cli@v0.26.3 -- tree-sitter test",
    "test:keywords": "bash scripts/test-keywords.sh",
    "test:node": "node --test bindings/node/*_test.js",
    "test": "npm run test:corpus && npm run test:keywords && npm run test:node",
    "parse": "npx --yes --package=tree-sitter-cli@v0.26.3 -- tree-sitter parse",
    "prestart": "npx --yes --package=tree-sitter-cli@v0.26.3 -- tree-sitter build --wasm",
    "start": "npx --yes --package=tree-sitter-cli@v0.26.3 -- tree-sitter playground",
    "release": "commit-and-tag-version",
    "prebuildify": "prebuildify --napi --strip"
  },
  "author": "redpandamc",
  "license": "MIT",
  "dependencies": {
    "node-addon-api": "^7.1.0",
    "node-gyp-build": "^4.8.0"
  },
  "devDependencies": {
    "commit-and-tag-version": "^12.0.0",
    "node-gyp": "^12.0.0",
    "prebuildify": "^6.0.0"
  },
  "peerDependencies": {
    "tree-sitter": "^0.25.0"
  },
  "peerDependenciesMeta": {
    "tree_sitter": {
      "optional": true
    }
  },
  "gypfile": true,
  "directories": {
    "test": "test"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/redpandamc/tree-sitter-sql-extended.git"
  },
  "bugs": {
    "url": "https://github.com/redpandamc/tree-sitter-sql-extended/issues"
  },
  "homepage": "https://github.com/redpandamc/tree-sitter-sql-extended#readme",
  "commit-and-tag-version": {
    "skip": {
      "tag": true
    }
  },
  "keywords": [
    "parser",
    "sql"
  ],
  "files": [
    "grammar.js",
    "grammar/**",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/*",
    "src/**",
    "tree-sitter.json"
  ]
}
